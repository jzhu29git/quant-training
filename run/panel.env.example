PANEL_AUTH_SECRET=change-me-panel-auth-secret
PANEL_PUBLIC_URL=http://localhost:3030
PANEL_USERS_FILE=/run-config/panel_users.json
PANEL_ADMIN_KEY=change-me-panel-admin-key
PANEL_API_ALLOWED_CIDRS=127.0.0.1/32,::1/128
PANEL_API_ALLOWED_SERVICE_NAMES=panel-web
# Optional single-user fallback if PANEL_USERS_FILE is missing:
# PANEL_USERNAME=admin
# PANEL_PASSWORD_HASH=scrypt$replace-with-generated-hash
FUTU_GATEWAY_BASE_URL=http://127.0.0.1:8080
PAPER_TRADING_MAX_ORDER_QTY=100
PIPELINE_AUTO_RUN_ENABLED=1
PIPELINE_AUTO_RUN_TIMEZONE=Asia/Shanghai
PIPELINE_AUTO_RUN_TIME=18:00
PIPELINE_AUTO_RUN_POLL_SECONDS=60
